# SendGrid (https://app.sendgrid.com/)
# 1. Create API Key: Settings → API Keys → Create API Key
# 2. Verify sender: Settings → Sender Authentication → Single Sender Verification
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=info@novatrixholding.com
SENDGRID_FROM_NAME=Novatrix Holding
SENDGRID_TO_EMAIL=info@novatrixholding.com

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=https://novatrixholding.com
